        <classes>
            <class name="tests.admin.AdminLoginPageTest"/>
        </classes>
    </test>
    <test name="Web Admin - Dashboard &amp; CRUD">
        <classes>
            <class name="tests.admin.AdminDashboardPageTest"/>
            <class name="tests.admin.AdminBookingsPageTest"/>
            <class name="tests.admin.AdminTripsPageTest"/>
            <class name="tests.admin.AdminVehiclesPageTest"/>
            <class name="tests.admin.AdminLocationsPageTest"/>
            <class name="tests.admin.AdminBusCompaniesPageTest"/>
            <class name="tests.admin.AdminUsersPageTest"/>
            <class name="tests.admin.AdminVASPageTest"/>
            <class name="tests.admin.AdminNotificationsPageTest"/>
            <class name="tests.admin.AdminPaymentsPageTest"/>
            <class name="tests.admin.AdminReviewsPageTest"/>
        </classes>
    </test>
</suite>
